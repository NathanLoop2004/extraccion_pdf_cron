# Opcional. Si no se define, el job usa Back up central shop/.env

# Tabla a procesar. Puede ser cs_documentos o ssss_emp1.cs_documentos.
PDF_JOB_TABLE=cs_documentos

# Perfil MariaDB tomado del .env de Back up central shop.
# Opciones: production, staging, localhost, replica, principal, ph.
# Alias utiles: prod=production, dev=staging, local=localhost.
PDF_JOB_DB_PROFILE=production

# Usar solo si en cs_documentos.url hay rutas relativas que no existen como archivo local.
# PDF_JOB_BASE_URL=https://centralshop.com.py

# Overrides opcionales de conexion. Si se cargan, pisan el perfil anterior.
# PDF_JOB_DB_HOST=
# PDF_JOB_DB_PORT=3306
# PDF_JOB_DB_USER=
# PDF_JOB_DB_PASSWORD=
# PDF_JOB_DB_NAME=ssss_emp1

# Linux/DigitalOcean: usar si la app principal no esta en ../Back up central shop.
# PDF_JOB_APP_ROOT=/var/www/central-shop

# Usar si quieres apuntar a un Chrome/Chromium del sistema.
# Si no se define, Puppeteer usa el Chrome que instala npm.
# PDF_JOB_CHROME_EXECUTABLE_PATH=/usr/bin/chromium

# OCR para PDFs escaneados como imagen.
PDF_JOB_OCR_ENABLED=true
PDF_JOB_OCR_LANGUAGE=spa+eng
PDF_JOB_OCR_MAX_PAGES=25
PDF_JOB_OCR_BATCH_PAGES=2
PDF_JOB_OCR_SCALE=2.4
# Objetivo de caracteres. 0 = sin objetivo.
# Para maxima extraccion puedes usar 100000.
PDF_JOB_TARGET_TEXT_CHARS=0
# true = marca error si no llega a PDF_JOB_TARGET_TEXT_CHARS.
PDF_JOB_REQUIRE_TARGET=false
# PDF_JOB_OCR_DEBUG=false
