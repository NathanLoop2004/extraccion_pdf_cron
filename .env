######################################################## JOB DOCUMENTOS PDF ###############################################################

# Perfil MariaDB usado por el job.
# production = MARIASQL_PRODUCTION_*
# dev/staging = MARIASQL_STAGING_*
# localhost/local = MARIASQL_LOCALHOST_*
# replica = MARIASQL_PRODUCTION_*_REPLICA
PDF_JOB_DB_PROFILE=production

# Tabla a procesar. Puede ser cs_documentos o ssss_emp1.cs_documentos.
PDF_JOB_TABLE=cs_documentos

# Ruta de la app principal. En DigitalOcean cambia esta ruta por la ruta real del proyecto.
PDF_JOB_APP_ROOT=C:/Users/Usuario/Desktop/cron + centralapp/Back up central shop

# Usar solo si en cs_documentos.url hay rutas relativas que no existen como archivo local.
# PDF_JOB_BASE_URL=

###############################################################################################################################################

